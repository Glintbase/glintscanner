# ─────────────────────────────────────────────────────────────────────────────
# Glintscanner — environment variables
#
# EVERYTHING HERE IS OPTIONAL. With no config the app runs in deterministic
# mode: scans work, but results are not persisted and no LLM harness runs.
# Copy this file to `.env.local` and fill in only what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (scan history, leaderboard, shareable reports) ──────────────────
# Without these, scans still run but nothing is saved and the leaderboard is empty.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client. Required for writes/persistence.
SUPABASE_SERVICE_ROLE_KEY=

# ── Upstash Redis (distributed rate limiting on /api/scan) ───────────────────
# Without these, an in-memory per-instance fallback limiter is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Firecrawl (premium content extraction for JS-heavy sites) ────────────────
# Optional. The zero-dep embedded extractor is used when this is unset.
FIRECRAWL_API_KEY=

# ── LLM providers (only for the agent journey harness; web deep + CLI --agent) ─
# Pick one. The MCP server never needs these — the calling agent reasons itself.
GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=
# GROQ_API_KEY=
# GROQ_MODEL=
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# OPENAI_API_KEY=
# OPENAI_MODEL=

# ── GitHub (enriches repo surfaces with stars/license/language) ──────────────
# Optional. Repo metadata is skipped when unset.
GITHUB_TOKEN=

# ── Scan tuning (optional overrides) ─────────────────────────────────────────
# SCAN_MAX_PAGES=
# SCAN_MAX_DURATION_MS=
# PATHFINDER_BEAM_WIDTH=

# ── Local dev toggles ────────────────────────────────────────────────────────
# Allow plain-HTTP targets (auto-on outside production).
# ALLOW_HTTP=true
# Enable the local fallback-storage rewrite proxy in production.
# ENABLE_FALLBACK_STORAGE=true
# DISABLE_FALLBACK_STORAGE=true
